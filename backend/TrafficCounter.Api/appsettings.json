{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=trafficcounter;Username=tc;Password=tc"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Security": {
    "BackendApiKey": "CHANGE_ME",
    "EnforceHashChain": false
  },
  "MediaMtx": {
    "ApiBaseUrl": "http://mediamtx:9997",
    "RtspBaseUrl": "rtsp://mediamtx:8554"
  },
  "VisionWorker": {
    "BaseUrl": "http://vision-worker:8000",
    "HealthPath": "/health",
    "StartPipelinePath": "/pipeline/start",
    "StopPipelinePath": "/pipeline/stop"
  },
  "HealthMonitor": {
    "SourceMissingFailureThreshold": 3,
    "DegradedFpsThreshold": 5.0
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
