{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=trafficcounter;Username=tc;Password=tc"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Security": {
    "BackendApiKey": "CHANGE_ME",
    "EnforceHashChain": false
  },
  "MediaMtx": {
    "ApiBaseUrl": "http://mediamtx:9997",
    "RtspBaseUrl": "rtsp://mediamtx:8554"
  },
  "VisionWorker": {
    "BaseUrl": "http://vision-worker:8000",
    "HealthPath": "/health",
    "StartPipelinePath": "/pipeline/start",
    "StopPipelinePath": "/pipeline/stop"
  },
  "HealthMonitor": {
    "SourceMissingFailureThreshold": 3,
    "DegradedFpsThreshold": 5.0
  },
  "Rounds": {
    "DurationSeconds": 60,
    "BetWindowSeconds": 15,
    "SettleDelaySeconds": 2,
    "Timing": {
      "Normal": {
        "DurationSeconds": 60,
        "BetWindowSeconds": 15
      },
      "Turbo": {
        "DurationSeconds": 60,
        "BetWindowSeconds": 15
      }
    },
    "Turbo": {
      "Enabled": false,
      "Probability": 0.25,
      "WarmupRoundsAfterProfileSwitch": 5
    },
    "MarketSets": {
      "Normal": [
        { "type": "under", "threshold": 10, "odds": 1.85, "label": "Menos de 10" },
        { "type": "range",  "min": 10, "max": 14, "odds": 2.40, "label": "10 a 14" },
        { "type": "exact", "targetValue": 12, "odds": 3.60, "label": "Exato 12" },
        { "type": "over",  "threshold": 15, "odds": 1.75, "label": "15 ou mais" }
      ],
      "Turbo": [
        { "type": "under", "threshold": 14, "odds": 1.95, "label": "Menos de 14" },
        { "type": "range",  "min": 14, "max": 18, "odds": 2.65, "label": "14 a 18" },
        { "type": "exact", "targetValue": 16, "odds": 4.10, "label": "Exato 16" },
        { "type": "over",  "threshold": 19, "odds": 1.82, "label": "19 ou mais" }
      ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
